{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NEVA MOBILE",
  "version": "0.2.1",
  "identifier": "com.nevamobile.erp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NEVA MOBILE • Telefon Alım Satım Yönetim Sistemi",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 720,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZBMTY4QkYyODQ5RUVFMTIKUldRUzdwNkU4b3NXK2thMDgxMm55czJUazZEWXNETE1CWnNZVnFuSlZtQ2hHbmVvV2wvSnArYTgK",
      "endpoints": [
        "https://github.com/coban9066/neva-mobile/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
